<UserControl x:Class="TreeChat.Views.FileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource CardBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SubtleBackground}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <Button Command="{Binding CreateNewFile}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="创建新的对话文件"
                        Margin="0,0,4,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,7,0"/>
                        <TextBlock Text="新建对话"/>
                    </StackPanel>
                </Button>
                <Button Command="{Binding OpenExistingFile}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        ToolTip="打开已有的对话文件">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE838;" FontFamily="{StaticResource IconFont}" FontSize="14" Margin="0,0,7,0"/>
                        <TextBlock Text="打开文件"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="14,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <TextBlock Text="最近打开"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="4,0,0,8"/>
            <ListBox Grid.Row="1" ItemsSource="{Binding RecentFiles}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Grid>
</UserControl>
