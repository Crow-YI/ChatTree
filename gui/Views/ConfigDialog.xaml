<Window x:Class="TreeChat.Views.ConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="AI配置"
        Width="450"
        Height="430"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="AI参数配置（基于ChatECNU）" FontSize="16" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <!-- API Key -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="API Key:" Width="100" VerticalAlignment="Center"/>
                <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Width="250"/>
            </StackPanel>

            <!-- API端点 -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="API端点:" Width="100" VerticalAlignment="Center"/>
                <TextBox Text="{Binding ApiEndpoint, UpdateSourceTrigger=PropertyChanged}" Width="250"/>
            </StackPanel>

            <!-- 模型名称 -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="模型名称:" Width="100" VerticalAlignment="Center"/>
                <TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" Width="250"/>
            </StackPanel>

            <!-- 随机性 Temperature（范围 0~2） -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="随机性:" Width="100" VerticalAlignment="Center"/>
                <TextBox Text="{Binding TemperatureText, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="范围:0~2" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock Text="{Binding TemperatureDisplay}" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>

            <!-- 核采样 TopP（范围 0~1） -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="核采样:" Width="100" VerticalAlignment="Center"/>
                <TextBox Text="{Binding TopPText, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="范围:0~1" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock Text="{Binding TopPDisplay}" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>

            <!-- MaxTokens（范围 1~8192） -->
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="最大Token数:" Width="100" VerticalAlignment="Center"/>
                <TextBox Text="{Binding MaxTokensText, UpdateSourceTrigger=PropertyChanged}"
                         Width="80" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="范围:1~8192" VerticalAlignment="Center" Margin="0,0,15,0"/>
                <TextBlock Text="{Binding MaxTokensDisplay}" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,30,0,0">
            <Button Content="取消" Width="80" Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
            <Button Content="确定" Width="80" Command="{Binding ConfirmCommand}" IsEnabled="{Binding IsValid}" Margin="0,0,10,0"/>
        </StackPanel>
    </Grid>
</Window>