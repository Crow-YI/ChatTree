<Window x:Class="TreeChat.Views.ConfigDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="模型配置"
        Width="480"
        Height="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="模型配置" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 配置名称 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="配置名称:" Width="100" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" Width="250"/>
                </StackPanel>

                <!-- 供应商 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="供应商:" Width="100" VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding ProviderOptions}"
                              SelectedIndex="{Binding ProviderIndex}"
                              Width="120" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- API Key -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="API Key:" Width="100" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding ApiKey, UpdateSourceTrigger=PropertyChanged}" Width="250"/>
                </StackPanel>

                <!-- API端点 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="API端点:" Width="100" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding ApiEndpoint, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="{Binding IsEndpointReadOnly}"
                             Width="250"
                             ToolTip="选择已知供应商时自动填充；选择「other」时可自定义"/>
                </StackPanel>

                <!-- 模型名称 -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="模型名称:" Width="100" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding ModelName, UpdateSourceTrigger=PropertyChanged}" Width="250"/>
                </StackPanel>

                <!-- 随机性 Temperature（范围 0~2） -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="随机性:" Width="100" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding TemperatureText, UpdateSourceTrigger=PropertyChanged}"
                             Width="80" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="范围:0~2" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding TemperatureDisplay}" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
                </StackPanel>

                <!-- 核采样 TopP（范围 0~1） -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="核采样:" Width="100" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding TopPText, UpdateSourceTrigger=PropertyChanged}"
                             Width="80" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="范围:0~1" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding TopPDisplay}" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
                </StackPanel>

                <!-- MaxTokens（范围 1~8192） -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,12">
                    <TextBlock Text="最大Token数:" Width="100" VerticalAlignment="Center"/>
                    <TextBox Text="{Binding MaxTokensText, UpdateSourceTrigger=PropertyChanged}"
                             Width="80" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="范围:1~8192" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBlock Text="{Binding MaxTokensDisplay}" Width="120" VerticalAlignment="Center" Foreground="Gray"/>
                </StackPanel>

                <!-- 状态信息 -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="#CC8800"
                           Margin="0,5,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="取消" Width="80" Command="{Binding CancelCommand}" Margin="0,0,10,0"/>
            <Button Content="确定" Width="80" Command="{Binding ConfirmCommand}" IsEnabled="{Binding IsValid}"/>
        </StackPanel>
    </Grid>
</Window>
