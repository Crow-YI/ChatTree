<UserControl x:Class="TreeChat.Views.TreeVisualizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TreeChat.ViewModels"
             xmlns:nodify="clr-namespace:Nodify;assembly=Nodify">
    <Grid Background="{StaticResource CardBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0"
                Background="{StaticResource SubtleBackground}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 模型配置按钮 + Popup 下拉框 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Grid>
                        <ToggleButton x:Name="ConfigToggle"
                                      Content="&#x2699; 模型配置 &#x25BC;"
                                      ToolTip="切换或管理模型配置"
                                      FontSize="12"
                                      Padding="8,4"
                                      MinWidth="120"
                                      Background="{StaticResource CardBackground}"
                                      BorderBrush="{StaticResource BorderBrush}"
                                      BorderThickness="1"
                                      Cursor="Hand"/>

                        <Popup IsOpen="{Binding IsChecked, ElementName=ConfigToggle}"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=ConfigToggle}"
                               StaysOpen="False"
                               PopupAnimation="Slide">
                            <Border Background="White"
                                    BorderBrush="{StaticResource StrongBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="8"
                                    MinWidth="240"
                                    MaxHeight="300">
                                <StackPanel>
                                    <!-- 当前激活信息 -->
                                    <TextBlock Text="{Binding ActiveProfileDisplay}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Margin="0,0,0,6"/>

                                    <Separator Margin="0,0,0,4"/>

                                    <!-- Profile 列表 -->
                                    <ItemsControl ItemsSource="{Binding DropdownProfiles}"
                                                  MaxHeight="200">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:DropdownProfileItem">
                                                <Grid Margin="0,1">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <Button Grid.Column="0"
                                                            Content="{Binding DisplayText}"
                                                            Command="{Binding ActivateCommand}"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            HorizontalContentAlignment="Left"
                                                            Padding="4,3"
                                                            Cursor="Hand"
                                                            FontSize="12">
                                                        <Button.Resources>
                                                            <Style TargetType="Border"/>
                                                        </Button.Resources>
                                                    </Button>

                                                    <Button Grid.Column="1"
                                                            Content="&#x270F;"
                                                            Command="{Binding EditCommand}"
                                                            Background="Transparent"
                                                            BorderBrush="Transparent"
                                                            BorderThickness="0"
                                                            Width="26"
                                                            Height="22"
                                                            Padding="0"
                                                            FontSize="11"
                                                            Cursor="Hand"
                                                            ToolTip="编辑此配置"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Separator Margin="0,4"/>

                                    <Button Content="+ 添加新模型"
                                            Command="{Binding AddNewProfileCommand}"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            BorderThickness="0"
                                            HorizontalContentAlignment="Left"
                                            Padding="4,3"
                                            Cursor="Hand"
                                            FontSize="12"/>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>

                <!-- 右侧留空 -->
            </Grid>
        </Border>

        <nodify:NodifyEditor Grid.Row="1"
                             x:Name="editor"
                             Background="{StaticResource CardBackground}"
                             Decorators="{Binding Decorators}"
                             Connections="{Binding Connections}"
                             SelectedItems="{Binding SelectedItems}"
                             CanSelectMultipleItems="False"
                             AllowDrop="True"
                             DragEnter="ScrollViewer_DragEnter"
                             DragOver="ScrollViewer_DragOver"
                             Drop="ScrollViewer_Drop">
            <nodify:NodifyEditor.DecoratorContainerStyle>
                <Style TargetType="nodify:DecoratorContainer">
                    <Setter Property="Location" Value="{Binding Location, Mode=OneWay}"/>
                </Style>
            </nodify:NodifyEditor.DecoratorContainerStyle>

            <nodify:NodifyEditor.DecoratorTemplate>
                <DataTemplate DataType="{x:Type vm:TreeNodeVM}">
                    <Border Background="{StaticResource SubtleBackground}"
                            BorderBrush="{Binding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Cursor="Hand"
                            MinWidth="52"
                            MinHeight="32"
                            Padding="10,6">
                        <Border.InputBindings>
                            <MouseBinding Gesture="LeftClick"
                                          Command="{Binding DataContext.SelectNodeCommand, RelativeSource={RelativeSource AncestorType=nodify:NodifyEditor}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <TextBlock Text="{Binding DisplayContent}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="12"/>
                    </Border>
                </DataTemplate>
            </nodify:NodifyEditor.DecoratorTemplate>

            <nodify:NodifyEditor.ConnectionTemplate>
                <DataTemplate DataType="{x:Type vm:ConnectionVM}">
                    <Line X1="{Binding SourcePoint.X}"
                          Y1="{Binding SourcePoint.Y}"
                          X2="{Binding TargetPoint.X}"
                          Y2="{Binding TargetPoint.Y}"
                          Stroke="#AEB0AA"
                          StrokeThickness="1.25"/>
                </DataTemplate>
            </nodify:NodifyEditor.ConnectionTemplate>

            <nodify:NodifyEditor.Style>
                <Style TargetType="nodify:NodifyEditor">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFileLoaded}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </nodify:NodifyEditor.Style>
        </nodify:NodifyEditor>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFileLoaded}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="28" Foreground="{StaticResource TextDisabledBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="尚未打开对话文件" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
