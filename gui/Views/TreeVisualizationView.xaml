<UserControl x:Class="TreeChat.Views.TreeVisualizationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:TreeChat.ViewModels"
             xmlns:nodify="clr-namespace:Nodify;assembly=Nodify">
    <Grid Background="{StaticResource CardBackground}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource SubtleBackground}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Command="{Binding ShowConfigCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="AI 参数配置">
                    <Viewbox Width="18" Height="18">
                        <Path Data="M2,5 H18 M2,10 H18 M2,15 H18 M7,3 V7 M13,8 V12 M5,13 V17"
                              Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                    </Viewbox>
                </Button>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                    <TextBlock Text="当前节点" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBox Text="{Binding SelectedNode.DisplayContent, Mode=OneWay}"
                             MinWidth="120" MaxWidth="220" IsReadOnly="True"/>
                </StackPanel>
                <Button Grid.Column="2"
                        Command="{Binding RenameNodeCommand}"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTip="重命名当前节点">
                    <Viewbox Width="18" Height="18">
                        <Path Data="M3,14.5 V17 H5.5 L16.5,6 L14,3.5 Z M12.5,5 L15,7.5 M3,4 H9"
                              Fill="Transparent" Stroke="{StaticResource TextPrimaryBrush}" StrokeThickness="1.5"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
                    </Viewbox>
                </Button>
            </Grid>
        </Border>

        <nodify:NodifyEditor Grid.Row="1"
                             x:Name="editor"
                             Background="{StaticResource CardBackground}"
                             Decorators="{Binding Decorators}"
                             Connections="{Binding Connections}"
                             SelectedItems="{Binding SelectedItems}"
                             CanSelectMultipleItems="False"
                             AllowDrop="True"
                             DragEnter="ScrollViewer_DragEnter"
                             DragOver="ScrollViewer_DragOver"
                             Drop="ScrollViewer_Drop">
            <nodify:NodifyEditor.DecoratorContainerStyle>
                <Style TargetType="nodify:DecoratorContainer">
                    <Setter Property="Location" Value="{Binding Location, Mode=OneWay}"/>
                </Style>
            </nodify:NodifyEditor.DecoratorContainerStyle>

            <nodify:NodifyEditor.DecoratorTemplate>
                <DataTemplate DataType="{x:Type vm:TreeNodeVM}">
                    <Border Background="{StaticResource SubtleBackground}"
                            BorderBrush="{Binding BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="4"
                            Cursor="Hand"
                            MinWidth="52"
                            MinHeight="32"
                            Padding="10,6">
                        <Border.InputBindings>
                            <MouseBinding Gesture="LeftClick"
                                          Command="{Binding DataContext.SelectNodeCommand, RelativeSource={RelativeSource AncestorType=nodify:NodifyEditor}}"
                                          CommandParameter="{Binding}"/>
                        </Border.InputBindings>
                        <TextBlock Text="{Binding DisplayContent}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="12"/>
                    </Border>
                </DataTemplate>
            </nodify:NodifyEditor.DecoratorTemplate>

            <nodify:NodifyEditor.ConnectionTemplate>
                <DataTemplate DataType="{x:Type vm:ConnectionVM}">
                    <Line X1="{Binding SourcePoint.X}"
                          Y1="{Binding SourcePoint.Y}"
                          X2="{Binding TargetPoint.X}"
                          Y2="{Binding TargetPoint.Y}"
                          Stroke="#AEB0AA"
                          StrokeThickness="1.25"/>
                </DataTemplate>
            </nodify:NodifyEditor.ConnectionTemplate>

            <nodify:NodifyEditor.Style>
                <Style TargetType="nodify:NodifyEditor">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFileLoaded}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </nodify:NodifyEditor.Style>
        </nodify:NodifyEditor>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    IsHitTestVisible="False">
            <StackPanel.Style>
                <Style TargetType="StackPanel">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsFileLoaded}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </StackPanel.Style>
            <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource IconFont}" FontSize="28" Foreground="{StaticResource TextDisabledBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="尚未打开对话文件" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,10,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
