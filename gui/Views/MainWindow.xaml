<Window x:Class="TreeChat.Views.MainWindow"
        x:Name="MainWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:TreeChat.ViewModels"
        xmlns:local="clr-namespace:TreeChat.Views"
        Title="树形AI聊天工具" Height="800" Width="1200"
        Background="{StaticResource WindowBackground}">
    <Window.Resources>
        <!-- 侧边栏按钮样式：覆盖全局 Button 样式 -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button" BasedOn="{x:Null}">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#505E6C"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="20"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#DCE6F0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== 左侧边栏（48px）===== -->
        <Border Grid.Column="0" Background="#F0F2F5" CornerRadius="4" Margin="0,0,4,0">
            <Grid>
                <!-- 顶部：树形视图 + 文件管理按钮 -->
                <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                    <Button x:Name="TreeViewButton" ToolTip="树形视图"
                            Command="{Binding ShowTreeViewCommand}"
                            Content="🌳">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveView}" Value="TreeView">
                                        <Setter Property="Background" Value="#DCE6F0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="FileViewButton" ToolTip="文件管理"
                            Command="{Binding ShowFileViewCommand}"
                            Content="📁">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveView}" Value="FileView">
                                        <Setter Property="Background" Value="#DCE6F0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- 底部：设置按钮 -->
                <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,8">
                    <Button x:Name="SettingsButton" ToolTip="设置"
                            Command="{Binding ShowSettingsCommand}"
                            Content="⚙️">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SidebarButtonStyle}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DCE6F0"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== 多功能内容区域 ===== -->
        <Grid Grid.Column="1" Margin="4,0,8,0">
            <!-- 树形图界面 -->
            <local:TreeVisualizationView x:Name="treeView"
                                         DataContext="{Binding TreeVisualizationVM}"/>

            <!-- 文件界面 -->
            <local:FileView x:Name="fileView"
                            DataContext="{Binding FileViewVM}"/>
        </Grid>

        <!-- ===== 节点信息展示界面 ===== -->
        <local:ChatInformationView Grid.Column="2"
                                   DataContext="{Binding ChatInformationVM}"/>
    </Grid>
</Window>
