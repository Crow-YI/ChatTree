# Auto detect text files and enforce CRLF on Windows
* text=auto

# Explicitly set specific file types
*.cs text eol=crlf
*.xaml text eol=crlf
*.csproj text eol=crlf
*.md text eol=crlf
*.json text eol=crlf
*.py text eol=lf

# Binary files should remain untouched
*.png binary
*.jpg binary
*.ico binary
